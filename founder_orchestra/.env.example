# =============================================================================
# FOUNDERS ORCHESTRA — ENVIRONMENT VARIABLES
# =============================================================================
# 
# HOW TO USE:
# 1. Copy this file and rename the copy to ".env.local"
#    (In terminal: copy .env.example .env.local)
# 2. Fill in the values below
# 3. NEVER commit .env.local to Git — it contains secrets!
#
# Owner: Backend Lead (Team Member C)
# =============================================================================

# ─────────────────────────────────────────────────────────────────────────────
# DATABASE — MongoDB
# ─────────────────────────────────────────────────────────────────────────────
# Get this from MongoDB Atlas: https://cloud.mongodb.com
# 1. Create a free cluster
# 2. Go to "Connect" > "Connect your application"
# 3. Copy the connection string and replace <password> with your DB password
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/founders-orchestra?retryWrites=true&w=majority

# ─────────────────────────────────────────────────────────────────────────────
# AI — Google Gemini
# ─────────────────────────────────────────────────────────────────────────────
# Get this from Google AI Studio: https://aistudio.google.com/apikey
# 1. Click "Create API Key"
# 2. Copy the key and paste below
# NOTE: This key is used by @langchain/google-genai (LangChain)
GOOGLE_GENERATIVE_AI_API_KEY=your_google_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# AI — Groq
# ─────────────────────────────────────────────────────────────────────────────
# Get this from Groq Console: https://console.groq.com/keys
GROQ_API_KEY_1=gsk_your_groq_api_key_1_here
GROQ_API_KEY_2=gsk_your_groq_api_key_2_here
GROQ_API_KEY_3=gsk_your_groq_api_key_3_here
GROQ_API_KEY_4=gsk_your_groq_api_key_4_here

# ─────────────────────────────────────────────────────────────────────────────
# AI — Tavily Web Search (for real-time market research)
# ─────────────────────────────────────────────────────────────────────────────
# Get this from Tavily: https://tavily.com
# Free tier: 1000 searches/month
# Used by: Startup Advisor, Market Research, and Marketing agents
TAVILY_API_KEY=tvly-your_tavily_api_key_here

# ─────────────────────────────────────────────────────────────────────────────
# AUTHENTICATION — NextAuth.js
# ─────────────────────────────────────────────────────────────────────────────
# Generate a random secret: Run this in terminal:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
NEXTAUTH_SECRET=your_nextauth_secret_here

# The URL where your app runs (change for production)
NEXTAUTH_URL=http://localhost:3000

# Credentials for the sole administrator account restricting the site
ADMIN_EMAIL=email@something.com
ADMIN_PASSWORD=password_haha

# ─────────────────────────────────────────────────────────────────────────────
# DEPLOYMENT — Vercel (these are set automatically on Vercel)
# ─────────────────────────────────────────────────────────────────────────────
# VERCEL_URL is auto-set by Vercel, no need to fill manually
# VERCEL_URL=
